{
  "name": "codev-cli",
  "version": "0.1.0",
  "description": "Interactive CLI that installs and configures AI coding agents.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/quickbeard/codev-cli.git"
  },
  "bin": {
    "codev": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "ai"
  ],
  "scripts": {
    "dev": "bun --hot src/index.tsx",
    "build": "bun build.ts",
    "start": "node dist/index.js",
    "test": "bun test",
    "typecheck": "bunx --bun tsc --noEmit",
    "check": "bunx --bun @biomejs/biome check",
    "fix": "bunx --bun @biomejs/biome check --write",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^6.0.2"
  }
}
